// OpenClaw config snippet — Tracebit alert hook via Gmail PubSub
// Add this to your OpenClaw config file (openclaw config path to find it)
// Replace YOUR_HOOK_TOKEN with a secure random token (openssl rand -hex 32)
// Restart the gateway after changes: openclaw gateway restart
{
  hooks: {
    enabled: true,
    token: "YOUR_HOOK_TOKEN",
    presets: ["gmail"],
    mappings: [
      {
        // Match any Gmail webhook event whose body contains "tracebit"
        match: {
          path: "gmail",
          body: "tracebit"
        },

        // Spawn an isolated agent session immediately
        action: "agent",
        wakeMode: "now",
        name: "Tracebit Alert",

        // Unique session key per alert (prevents duplicate sessions for same email)
        sessionKey: "hook:tracebit-alert:{{messages[0].id}}",

        // The message sent to the spawned agent — includes full email content
        messageTemplate: "TRACEBIT CANARY ALERT\n\nFrom: {{messages[0].from}}\nSubject: {{messages[0].subject}}\nTime: {{messages[0].date}}\n\n{{messages[0].body}}\n\n---\nA Tracebit canary has been triggered. Follow the incident response playbook in your tracebit-canaries skill.",

        // Use Claude Sonnet for incident response
        model: "sonnet",

        // Deliver agent response to the last-active messaging channel
        deliver: true,
        channel: "last"
      }
    ]
  }
}
