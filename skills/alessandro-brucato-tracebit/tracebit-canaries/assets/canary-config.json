{
  "_comment": "Tracebit canary configuration template. Values are filled by 'tracebit deploy all'.",
  "_note": "The CLI auto-manages this config. Edit only if using API-based deployment (see references/api-reference.md).",

  "tracebit_api_url": "https://community.tracebit.com",
  "token_path": "~/.config/tracebit/token",
  "canary_state_path": "~/.config/tracebit/canaries.json",

  "canary_name": "agent-canary",
  "source": "openclaw-skill",
  "source_type": "endpoint",

  "deploy_types": ["aws", "ssh", "cookie", "username-password", "email"],

  "labels": [
    {"name": "agent", "value": "openclaw"},
    {"name": "purpose", "value": "prompt-injection-detection"},
    {"name": "env", "value": "production"}
  ],

  "placement": {
    "aws": "~/.aws/credentials [canary]",
    "ssh": "~/.ssh/tracebit-canary",
    "cookie": "browser local storage",
    "username-password": "password manager / .env files",
    "email": "agent config / contact lists"
  },

  "alert_timing": {
    "aws": "5-15 minutes (CloudTrail latency)",
    "ssh": "1-3 minutes",
    "cookie": "1-5 minutes",
    "username-password": "1-5 minutes",
    "email": "near-instant (~1 minute)"
  }
}
